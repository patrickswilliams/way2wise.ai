.DS_Store
.AppleDouble
.LSOverride
._*
.__MACOSX/
__MACOSX/
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.lnk
*.cab
Network Trash Folder
Temporary Items
$RECYCLE.BIN/

